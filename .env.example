APP_NAME=Relevance Gateway
APP_SECRET_KEY=change-me-super-secret

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# 本地默认使用文件数据库；部署到 Vercel 时请改成 libsql:// 或 https:// 地址
DATABASE_URL=file:data/gateway.db
DATABASE_AUTH_TOKEN=
# 如果使用 Vercel Marketplace 的 Supabase，可直接依赖平台注入的 POSTGRES_URL
POSTGRES_URL=

PORT=8080
ENABLE_BUFFERED_STREAM_COMPAT=true
UPSTREAM_POLL_INTERVAL_SECONDS=1.5
UPSTREAM_POLL_TIMEOUT_SECONDS=300
STREAM_HEARTBEAT_INTERVAL_SECONDS=8
MODEL_CATALOG_TTL_SECONDS=86400
MODEL_CATALOG_REFRESH_TIMEOUT_SECONDS=20
DEPLOYMENT_COOLDOWN_SECONDS=30

SELF_TEST_UPSTREAM_PROJECT=
SELF_TEST_UPSTREAM_REGION=
SELF_TEST_UPSTREAM_API_KEY=
